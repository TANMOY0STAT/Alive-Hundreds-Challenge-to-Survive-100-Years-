rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection
    match /users/{uid} {
      allow read: if request.auth.uid == uid || resource.data.privacy == 'public';
      allow write: if request.auth.uid == uid;
      
      // User logs subcollection
      match /logs/{logId} {
        allow read: if request.auth.uid == uid;
        allow write: if request.auth.uid == uid;
      }
      
      // User stats subcollection
      match /stats/{statId} {
        allow read: if request.auth.uid == uid;
        allow write: if request.auth.uid == uid;
      }
      
      // User habits subcollection
      match /habits/{habitId} {
        allow read: if request.auth.uid == uid;
        allow write: if request.auth.uid == uid;
      }
    }
    
    // Leaderboard collection - public read
    match /leaderboard/{uid} {
      allow read: if true;
      allow write: if request.auth.uid == uid;
    }
  }
}
